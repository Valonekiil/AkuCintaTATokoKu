[sub_resource type="GDScript" id="GDScript_h5j4x"]
resource_name = "Player.gd"
script/source = "extends CharacterBody2D
class_name Player

const SPEED = 300.0
const JUMP_VELOCITY = -400.0
var cur_shop:DynamicShop
@onready var notifier: Label = $Notifier

func _ready() -> void:
	notifier.visible = false

func _physics_process(delta: float) -> void:
	var direction_X := Input.get_axis(\"ui_left\", \"ui_right\")
	if direction_X:
		velocity.x = direction_X * SPEED
	else:
		velocity.x = move_toward(velocity.x, 0, SPEED)
	var direction_y := Input.get_axis(\"ui_up\", \"ui_down\")
	if direction_y:
		velocity.y = direction_y * SPEED
	else:
		velocity.y = move_toward(velocity.y, 0, SPEED)

	move_and_slide()

func show_notif()-> void:
	notifier.visible = true

func hide_notif()-> void:
	notifier.visible = false

func check_shop():
	var shop = $\"../SakOnokE\"
	var all_items:Array[DynamicShopItem] = shop.get_all_registered_items()
	print(\"Total items: \", all_items.size())
	print(\"First item name: \", all_items[0].display_name)
	
	var potion = shop.find_item_by_id(\"CONS_001\")
	print(\"Found potion: \", potion != null)
	if potion:
		print(\"Potion price: \", potion.base_worth)

func _unhandled_input(event: InputEvent) -> void:
	if Input.is_key_pressed(KEY_E):
		check_shop()
	if Input.is_key_pressed(KEY_TAB):
		$CanvasLayer/Control.visible = !$CanvasLayer/Control.visible
"

